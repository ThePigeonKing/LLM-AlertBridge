# =============================================================================
# Cloud VM inventory (internal IPv4, ru-central1-a)
#   core-compute           10.128.0.29  — deploy Docker Compose here
#   target-1-compute       10.128.0.35
#   target-2-compute       10.128.0.14
#   attacker-compute       10.128.0.36
#   openvpn-access-server  10.128.0.7
# Full table: docs/network.md
# =============================================================================

# Docker Compose only: host publish for FastAPI (default = internal IP on core-compute).
# On your laptop for local Docker: ALERTBRIDGE_HTTP_PUBLISH=8000:8000
# ALERTBRIDGE_HTTP_PUBLISH=10.128.0.29:8000:8000

# -- LM Studio (reachable from core-compute) ---------------------------------
# Option A: laptop VPN client IP + LM Studio port (often 1234):
#   LM_STUDIO_BASE_URL=http://YOUR_LAPTOP_VPN_IP:1234/v1
# Option B: SSH tunnel endpoint (e.g. LM Studio forwarded on openvpn-access-server):
#   LM_STUDIO_BASE_URL=http://10.128.0.7:8080/v1
LM_STUDIO_BASE_URL=http://YOUR_LAPTOP_VPN_IP:1234/v1
LM_STUDIO_MODEL=your-model-name-here

# -- Wazuh (Docker stack on core-compute; same Compose network as backend) ---
# Compose sets WAZUH_API_URL=https://wazuh.manager:55000 for the backend container.
# For a local run without Docker, point at the manager yourself, e.g.:
#   WAZUH_API_URL=https://10.128.0.29:55000
WAZUH_API_USER=wazuh-wui
# Must match API_PASSWORD for wazuh.manager / wazuh.dashboard and password in
# deploy/wazuh/config/wazuh_dashboard/wazuh.yml if you change it.
WAZUH_API_PASSWORD=somesupersecurepass
WAZUH_VERIFY_SSL=false

# Wazuh ports bind to this host IP on core-compute (agents + API). Laptop: 127.0.0.1
# WAZUH_PUBLISH_IP=10.128.0.29

# -- Database (Docker Compose overrides this to the db service) --------------
DATABASE_URL=postgresql+asyncpg://alertbridge:alertbridge@localhost:5432/alertbridge

# -- Application -------------------------------------------------------------
LOG_LEVEL=INFO
