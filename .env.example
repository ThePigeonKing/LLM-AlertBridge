# -- LM Studio (runs on the analyst laptop, reachable via VPN) --
# Set this to your laptop's VPN IP when deploying on core-compute
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=your-model-name-here

# -- Wazuh (runs on core-compute, same host as the backend) ----
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=changeme
WAZUH_VERIFY_SSL=false

# -- Database (PostgreSQL, runs on core-compute in Docker) -----
DATABASE_URL=postgresql+asyncpg://alertbridge:alertbridge@localhost:5432/alertbridge

# -- Application -----------------------------------------------
LOG_LEVEL=INFO
